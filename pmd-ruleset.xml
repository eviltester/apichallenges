<?xml version="1.0"?>
<ruleset name="Thingifier PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/schema/ruleset_2_0_0.xsd">
    <description>
        Focused static analysis rules for source style problems that are easy to miss during refactoring.
    </description>

    <rule ref="category/java/codestyle.xml/UnnecessaryFullyQualifiedName">
        <properties>
            <property name="reportStaticFields" value="false"/>
            <property name="reportStaticMethods" value="false"/>
        </properties>
    </rule>
</ruleset>
