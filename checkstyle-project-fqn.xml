<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryLegacySnapshotEscape"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\]ERInstanceData\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryLegacySnapshotEscape"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]repository[/\\]inmemory[/\\]InMemoryThingRepository\.java"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceCollectionUse"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceCollectionUse"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]test[/\\]java[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceConstruction"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceConstruction"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]test[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceMutableFields"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceMutableFields"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]test[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceRelationshipsType"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]main[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="SuppressionSingleFilter">
        <property name="id" value="repositoryEntityInstanceRelationshipsType"/>
        <property name="files" value=".*[/\\]ercoremodel[/\\]src[/\\]test[/\\]java[/\\]uk[/\\]co[/\\]compendiumdev[/\\]thingifier[/\\]core[/\\]domain[/\\]instances[/\\].*"/>
    </module>
    <module name="TreeWalker">
        <module name="RegexpSinglelineJava">
            <property name="id" value="hiddenRepositoryTestSupport"/>
            <property name="format" value="\b(ThingifierRepositoryTestSupport|EntityInstanceTestSupport|MutableEntityInstanceTestSupport|RepositoryUrlQueryTestSupport)\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Do not hide repository/draft access behind broad test-support helpers; use EntityInstanceDraft and ThingRepository directly."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryWriteTestSupportClass"/>
            <property name="format" value="\bclass\s+\w*(Repository|Instance)\w*TestSupport\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Shared test support classes must not hide repository writes or mutable EntityInstance internals."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="entityInstanceDraftMaterialization"/>
            <property name="format" value="\btoEntityInstance\s*\("/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="EntityInstanceDraft should describe changes only; materialize explicit snapshots with EntityInstance.fromDraft or persist through ThingRepository."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="entityInstanceTestOnlyAutoIdHelpers"/>
            <property name="format" value="\b(addAutoGUIDstoInstance|addAutoIncrementIdsToInstance)\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Auto ID generation belongs in ThingRepository tests and APIs, not EntityInstance test-only mutation helpers."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryLegacySnapshotEscape"/>
            <property name="format" value="\b(getInstanceData|getThingInstancesNamed|getInstancesForSingularOrPluralNamedEntity|getThings|cloneWithDifferentData|createInstanceCollectionFor|getAllInstanceCollections|getInstanceCollectionForEntityNamed)\s*\("/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Use repository-native APIs instead of legacy snapshot escape methods."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryEntityInstanceCollectionUse"/>
            <property name="format" value="\bEntityInstanceCollection\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Thingifier and Challenger runtime code should use ThingRepository instead of EntityInstanceCollection."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositorySimpleQueryUse"/>
            <property name="format" value="\bSimpleQuery\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="SimpleQuery is removed; use RepositoryUrlQuery or repository APIs."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryEntityInstanceConstruction"/>
            <property name="format" value="\bnew\s+EntityInstance\s*\("/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Persisted EntityInstance creation must go through EntityInstanceDraft and ThingRepository."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryEntityInstanceMutableFields"/>
            <property name="format" value="\.getFields\s*\("/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="EntityInstance fields are mutable internals; use read-only field APIs or repository access."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="repositoryEntityInstanceRelationshipsType"/>
            <property name="format" value="\bEntityInstanceRelationships\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Mutable relationship internals must stay inside the domain instance package; use ThingRepository relationship APIs."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="productionDeprecatedApi"/>
            <property name="format" value="@Deprecated\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Production code should not add @Deprecated APIs without an explicit static-analysis suppression."/>
        </module>
    </module>
</module>
