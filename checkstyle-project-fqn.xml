<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <module name="TreeWalker">
        <module name="RegexpSinglelineJava">
            <property name="format" value="^(?!\s*(package|import)\b).*uk\.co\.compendiumdev\.(thingifier|challenge)\.testsupport\.ThingifierRepositoryTestSupport\b"/>
            <property name="ignoreComments" value="true"/>
            <property name="message" value="Import ThingifierRepositoryTestSupport instead of using its fully-qualified name."/>
        </module>
    </module>
</module>
