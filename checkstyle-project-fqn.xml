<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">

<module name="Checker">
    <module name="TreeWalker">
        <module name="RegexpSinglelineJava">
            <property name="id" value="noRemovedHttpServerImports"/>
            <property name="format" value="^import s[p]ark\."/>
            <property name="ignoreComments" value="true"/>
            <property name="message"
                      value="SparkJava must not be reintroduced; API Challenges uses Thingifier's neutral HTTP server surface."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="noDirectJavalinImports"/>
            <property name="format" value="^import io\.javalin\."/>
            <property name="ignoreComments" value="true"/>
            <property name="message"
                      value="API Challenges should depend on Thingifier's HTTP server adapter, not Javalin directly."/>
        </module>
        <module name="RegexpSinglelineJava">
            <property name="id" value="noThingifierRootParent"/>
            <property name="format" value="thingifier-root|uk\.co\.compendiumdev\.thingifier&lt;/parent>"/>
            <property name="ignoreComments" value="true"/>
            <property name="message"
                      value="The extracted repo must use apichallenges-root as its Maven parent."/>
        </module>
    </module>
    <module name="RegexpMultiline">
        <property name="id" value="newRepoHasNoThingifierModules"/>
        <property name="format"
                  value="(?s)&lt;modules&gt;.*&lt;module&gt;(ercoremodel|thingifier|thingifier-yaml|examplemodels|thingifier-crud-ui|todoManagerRestAuto|standAlone|thingifierapp|swaggerizer)"/>
        <property name="message"
                  value="The API Challenges repo should only include Challenger modules in its Maven reactor."/>
    </module>
</module>
