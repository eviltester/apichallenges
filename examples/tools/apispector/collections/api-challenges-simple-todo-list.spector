  "requests": {
    "56a31ce6-17be-46bb-bf17-49b97ff7d8fe": {
      "id": "56a31ce6-17be-46bb-bf17-49b97ff7d8fe",
      "name": "return all the instances of todo",
      "method": "GET",
      "url": "{{baseUrl}}/todos",
      "headers": [],
      "params": [],
      "auth": {
        "type": "none"
      },
      "body": {
        "mode": "none"
      },
      "description": "return all the instances of todo",
      "meta": {
        "tags": [
          "default"
        ]
      },
      "schema": "{\n  \"type\": \"array\",\n  \"description\": \"todos\",\n  \"items\": {\n    \"type\": \"object\",\n    \"description\": \"todo\",\n    \"properties\": {\n      \"id\": {\n        \"type\": \"integer\",\n        \"description\": \"Field is an ID and should not be amended or set.\",\n        \"example\": \"80\"\n      },\n      \"title\": {\n        \"type\": \"string\",\n        \"description\": \"The title of the TODO Item. Value is mandatory. Value can not be empty. Maximum length allowed is 50.\",\n        \"example\": \"A title\"\n      },\n      \"doneStatus\": {\n        \"type\": \"boolean\",\n        \"description\": \"Status to track the todo completion. Value must be a Boolean (true, false) value.\",\n        \"example\": \"false\"\n      },\n      \"description\": {\n        \"type\": \"string\",\n        \"description\": \"Longer description of the todo. Maximum length allowed is 200.\",\n        \"example\": \"my description\"\n      }\n    },\n    \"title\": \"todo\",\n    \"xml\": {\n      \"name\": \"todo\",\n      \"wrapped\": true\n    }\n  },\n  \"title\": \"todos\",\n  \"xml\": {\n    \"wrapped\": true\n  }\n}"
    },
    "da31b4dc-a3ee-4dbf-9bbe-53deab055443": {
      "id": "da31b4dc-a3ee-4dbf-9bbe-53deab055443",
      "name": "we should be able to create todo without a ID using the field values in the body of the message. A maximum of 20 todos is allowed.",
      "method": "POST",
      "url": "{{baseUrl}}/todos",
      "headers": [],
      "params": [],
      "auth": {
        "type": "none"
      },
      "body": {
        "mode": "json",
        "json": "{\n  \"title\": \"A title\",\n  \"doneStatus\": \"false\",\n  \"description\": \"my description\"\n}"
      },
      "description": "we should be able to create todo without a ID using the field values in the body of the message. A maximum of 20 todos is allowed.",
      "meta": {
        "tags": [
          "default"
        ]
      },
      "schema": "{\n  \"type\": \"object\",\n  \"description\": \"todo\",\n  \"properties\": {\n    \"id\": {\n      \"type\": \"integer\",\n      \"description\": \"Field is an ID and should not be amended or set.\",\n      \"example\": \"80\"\n    },\n    \"title\": {\n      \"type\": \"string\",\n      \"description\": \"The title of the TODO Item. Value is mandatory. Value can not be empty. Maximum length allowed is 50.\",\n      \"example\": \"A title\"\n    },\n    \"doneStatus\": {\n      \"type\": \"boolean\",\n      \"description\": \"Status to track the todo completion. Value must be a Boolean (true, false) value.\",\n      \"example\": \"false\"\n    },\n    \"description\": {\n      \"type\": \"string\",\n      \"description\": \"Longer description of the todo. Maximum length allowed is 200.\",\n      \"example\": \"my description\"\n    }\n  },\n  \"title\": \"todo\",\n  \"xml\": {\n    \"name\": \"todo\",\n    \"wrapped\": true\n  }\n}"
    },
