      "postRequestScript": "const json = sp.response.json();\n\nsp.test(\"JSON field equals value\", function() {\n  sp.expect(json.challenges[0].status).to.equal(true);\n  sp.expect(json.challenges[1].status).to.equal(true);\n  sp.expect(json.challenges[2].status).to.equal(true);\n});"
