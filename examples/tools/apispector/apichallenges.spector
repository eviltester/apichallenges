{
  "version": "1.0",
  "collections": [
    "collections/api-challenges-simple-todo-list.spector"
  ],
  "environments": [
    "environments/local-api-challenges.env.json"
  ],
  "activeEnvironmentId": null,
  "settings": {
    "proxy": {
      "url": "http://127.0.0.1:8080"
    },
    "tls": {
      "rejectUnauthorized": true
    },
    "piiMaskPatterns": [
      "authorization",
      "password",
      "api-key",
      "x-api-key"
    ]
  }
}